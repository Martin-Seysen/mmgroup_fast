/** @file mm_op_fast_mode1.c

 File ``mm_op_fast_init.c`` provides basic functions for manipulating
 structures of type ``mmv_fast_matrix_type`` with ``mode = 1``. Such
 a structure represents a matrix of up to four row vectors of integers
 modulo 3 acting on the Griess algebra.
*/

/// @cond DO_NOT_DOCUMENT 
#define MM_OP_FAST_ALLOC
#include "mm_op_fast.h"
#include "mm_op_sub.h"   
/// @endcond 


//  %%GEN h
/// @cond DO_NOT_DOCUMENT 
//  %%GEN c


/*********************************************************************
** Obtain pointer to the data in the structure
*********************************************************************/


/** 
  @brief Return pointer to data of structure of type mmv_fast_matrix_type

  Return a pointer to the data in a structure of
  type ``mmv_fast_matrix_type`` referred by ``pm`` if ``pm->mode``
  is equal to 1, and data are present. Return NULL otherwise.
*/
static mmv_fast_type* ptr_data_mode1(mmv_fast_matrix_type *pm)
{
     if (pm != NULL && pm->mode == 1 && pm->p == 3) {
         mmv_fast_type **p_buf = pm->p_v.p_vb;
         mmv_fast_type *p_data = p_buf[pm->current & 1];
         return p_data;
     } 
     return NULL;
}


/*********************************************************************
** Store data at some entries of the structure
*********************************************************************/



/** 
  @brief Store data to a structure of type mmv_fast_matrix_type

  The function stores data to a structure ``a`` of
  type ``mmv_fast_matrix_type`` referred by ``pa``. The data to be
  stored are given by the array ``data`` of length ``len``.

  Each entry ``x`` of that array refers to a column ``j`` in the
  structure ``a`` to  be modified. Bits 31,...,8 of an entry contain
  the index ``j`` of the column to be modified in 'sparse'
  representation. Bits 7,...,0 contain the data to be stored at this
  entry. We store the value ``(x >> (2 * k)) & 3`` in row ``k``
  and column ``j`` of the structure ``a`` for ``0 <= k < 4``. 

  Illegal indices are ignored. The function performs no action
  if ``a->mode != 1``, or if no data are allocated for ``a``.

  The function returns 0 if all data have been stored successfully
  and -1 otherwise. The function fails if ``a->mode != 1``.
*/
// %%EXPORT p
int32_t mm_op_fast_mode1_put(mmv_fast_matrix_type *pm, uint32_t *data, uint32_t len)
{
    uint32_t i;
    int32_t v1, v2, status = 0;
    mmv_fast_type *pb = ptr_data_mode1(pm);
    if (pb == NULL) return -1;
    for (i = 0; i < len; ++i) {
        v1 = mm_aux_index_sparse_to_intern(data[i] & 0xffffff00UL);
        if (v1 >= 0) {
            uint8_t b = (uint8_t)(data[i] & 0xff);
            pb->b[v1] = b;
            v2 = mm_aux_index_check_intern(v1);
            if (v2 > 0) pb->b[v2] = b;
        } else status = -1;
    }
    return status;
}



/**
  @brief An extremely dangerous low-level function!

  This function is not for public use!

  It stores the byte ``value`` at position ``index`` of the data
  vector in the structure referreded by ``pm``. Inappropriate use
  may lead to inconsistent data!
*/
// %%EXPORT p
void mm_op_fast_mode1_poke(mmv_fast_matrix_type *pm, uint32_t index, uint32_t value)
{
    mmv_fast_type *pb = ptr_data_mode1(pm);
    if (pb == NULL || index >= MM_FAST_BYTELENGTH) return;
    pb->b[index] = (uint8_t)(value & 0xff);
}



/*********************************************************************
** Zero the vector in the structure
*********************************************************************/


/**
  @brief Store zero to structure of type mmv_fast_matrix_type

  The function stores zero to a structure ``a`` of
  type ``mmv_fast_matrix_type`` referred by ``pa``. It performs
  no action if ``a->mode != 1``.
*/
// %%EXPORT p
void mm_op_fast_mode1_zero(mmv_fast_matrix_type *pm)
{
    mmv_fast_type *pb = ptr_data_mode1(pm);
    if (pb != 0) memset(pb, 0, MM_FAST_BYTELENGTH * sizeof(uint8_t));
}


/*********************************************************************
** Add data to some entries in the structure
*********************************************************************/


/**
  @brief Add data to a structure of type mmv_fast_matrix_type

  The function adds data to a structure ``a`` of
  type ``mmv_fast_matrix_type`` referred by ``pa``. The data to be
  stored are given by the array ``data`` of length ``len``.

  Each entry ``x`` of that array refers to a column ``j`` in the
  structure ``a`` to  be modified. The format of such an entry
  is as in function ``mm_op_fast_mode1_put``. But we add the
  value  ``(x >> (2 * k)) & 3`` to the entry in row ``k``
  and column ``j`` of the structure ``a`` for ``0 <= k < 4``,
  instead of storing it there.

  Illegal indices are ignored. The function performs no action
  if ``a->mode != 1``, or if no data are allocated for ``a``.

  The function returns 0 if all data have been stored successfully
  and -1 otherwise. The function fails if ``a->mode != 1``.
*/
// %%EXPORT p
int32_t mm_op_fast_mode1_add_sparse(mmv_fast_matrix_type *pm, uint32_t *data, uint32_t len)
{
    uint32_t i;
    int32_t v1, v2, status = 0;
    mmv_fast_type *pb = ptr_data_mode1(pm);
    if (pb == NULL) return -1;
    for (i = 0; i < len; ++i) {
        v1 = mm_aux_index_sparse_to_intern(data[i] & 0xffffff00UL);
        if (v1 >= 0) {
            uint8_t x = (uint8_t)(data[i] & 0xff), r;
            uint8_t y = pb->b[v1];
            r = x & y;
            r |= (r << 1) & (x ^ y);
            r &= 2;
            r = x + y - r - (r >> 1);
            pb->b[v1] = r;
            v2 = mm_aux_index_check_intern(v1);
            if (v2 > 0) pb->b[v2] = r;
        } else status = -1;
    }
    return status;
}






/*********************************************************************
** Load data from the structure
*********************************************************************/



/** 
  @brief Load data from structure of type mmv_fast_matrix_type

  The function loads data from a structure ``a`` of
  type ``mmv_fast_matrix_type`` referred by ``pa``. The data are
  stored to an array ``data`` of length ``len``.

  Each entry ``x`` of array ``data`` describes a column in the 
  structure ``a`` to  be loaded. Bits 31,...,8 of an entry contain
  the index ``j`` of the column to be loaded in 'sparse'
  representation. Bits 7,...,0 of entry ``data`` are modified so
  that will contain the data read frm the array. We store the
  value of row ``j`` and column ``k``  the structure ``a`` in the
  bits ``(2*i+1, 2*i)`` of that entry for ``0 <= k < 4``. These
  stored values are reduced modulo 3.

  Bit 7,...,0  of an entry of array ``data`` are set to zero if the
  corresponding entries of ``a``are not present.
  
  The function returns 0 if all data have been loaded successfully
  and -1 otherwise. The function fails if ``a->mode != 1``.
*/
// %%EXPORT p
int32_t mm_op_fast_mode1_get(mmv_fast_matrix_type *pm, uint32_t *data, uint32_t len)
{
    uint32_t i;
    int32_t v1, status = 0;
    mmv_fast_type  *pb = ptr_data_mode1(pm);
    if (pb == NULL) {
        for (i = 0; i < len; ++len) data[i] |= 0xffUL; 
        return -1;
    }
    for (i = 0; i < len; ++i) {
        data[i] &= 0xffffff00UL;  
        v1 = mm_aux_index_sparse_to_intern(data[i]);
        if (v1 >= 0) {
            uint8_t b = pb->b[v1];
            uint8_t tmp = (b ^ (b >> 1)) & 0x55;
            b ^= tmp ^ (tmp << 1);
            data[i] |= b;
        }
        else {
            status = -1;
            data[i] |= 0xffUL; 
        }
    }
    return status;
}



/*********************************************************************
** Load signs of some entries in the structure
*********************************************************************/





/** 
  @brief Load signs from structure of type mmv_fast_matrix_type

  The function extracts certain entries from row ``row`` in a
  structure of type ``mmv_fast_matrix_type`` referred by ``pa``.
  The extracted entries depend on the data in the array ``sp`` of
  length ``length``; they are merged into that array. Operation of
  this function on the array ``sp`` is precisely the same as the
  operation of function ``mm_aux_mmv_extract_sparse`` in
  the *mmgroup* package. For details we refer to the documentation
  of that function.

  The return type of this function is void, as that of
  function ``mm_aux_mmv_extract_sparse``. If any of the
  arguments ``pm``, ``row``, or ``sp`` is illegal then no action
  is performed.
*/
// %%EXPORT p
void mm_op_fast_mode1_extract_sparse(mmv_fast_matrix_type *pm, uint32_t row, uint32_t *sp, uint32_t length)
{
    uint32_t sh = 2 * row;
    mmv_fast_type  *pf = ptr_data_mode1(pm);
    uint8_t *pb = pf->b;
    if (pb == NULL || row >= 4 || sp == NULL) return;

    for ( ;length--; ++sp) {
        uint32_t i_intern;
        if ((*sp & 0xE000000UL) == 0) continue;
        i_intern = mm_aux_index_sparse_to_intern(*sp);
        if (i_intern >= MM_AUX_LEN_V) continue;
        uint32_t k = (pb[i_intern] >> sh) & 3;
        k += (k + 1) >> 2;
        k = (k ^ *sp) & 3;
        *sp = (*sp & 0xffffff00) + k;
    }
}



/*********************************************************************
** Check if row vectors in the structure are zero
*********************************************************************/

/// @cond DO_NOT_DOCUMENT 

static inline void zero_diagBC(mmv_fast_matrix_type *pm)
{
    uint32_t i;
    mmv_fast_type  *pf = ptr_data_mode1(pm);
    if (pf == NULL) return;
    uint8_t *pb = pf->b + 24 * 32;
    for (i = 0; i < 24 * 32; i += 33) pb[i + 24*32] = pb[i] = 0;
}

// %%FOR SIZE in [24, 32]
static inline int32_t
check_zero_rows%{SIZE}(mmv_fast_matrix_type *pm, uint32_t start, uint32_t n)
{
    uint32_t i;
    uint64_t res = 0;
    mmv_fast_type  *pf = ptr_data_mode1(pm);
    if (pf == NULL) return -0x10;
    mmv_fast_row32_type *p_row = pf->r32 + start;
  #ifdef GCC_VECTORS
    mmv_fast_row32_type acc;
    for (i = 0; i < 32; ++i) acc.b[i] = 0;
    for (i = 0; i < n; ++i) {
        acc.v8_32[0] |= p_row[i].v8_32[0] ^ (p_row[i].v8_32[0] >> 1);
    }
    res = acc.u64[0] | acc.u64[1] | acc.u64[2];
    // %%IF* SIZE == 32
    res |= acc.u64[3];
    // %%END IF
  #else
    for (i = 0; i < n; ++i) {
        // %%FOR* j in range(SIZE // 8)
        res |= p_row[i].u64[%{j}] ^ (p_row[i].u64[%{j}] >> 1);
        // %%END FOR
    }
  #endif
    res |= res >> 32;
    res |= res >> 16;
    res |= res >> 8;
    res = ((res & 0x40) >> 3) ^ ((res & 0x10) >> 2)
        ^ ((res & 0x4) >> 1) ^ (res & 0x1);
    return (int32_t)(res & 0xf);
}

// %%END FOR

/// @endcond 


/** 
  @brief Check if structure of type mmv_fast_matrix_type is zero

  The function checks if each of the four row vectors in the
  structure referred by ``pm`` is zero. It sets bit ``i`` of the
  return value if and only if the ``i``-th row vector is nonzero. If
  bit ``i`` in the argument ``check`` is zero then bit ``i`` of the
  return value is set to zero without inspecting the ``i``-th row.

  The function returns a negative value if any of these row vectors
  cannot be accessed.
*/
// %%EXPORT p
int32_t mm_op_fast_mode1_check_zero(mmv_fast_matrix_type *pm, uint32_t check)
{
    int32_t res = 0, status, chk = check & 0xf;
    zero_diagBC(pm);
    status = check_zero_rows24(pm, 0, 72);
    if (status < 0) return status;
    res |= status & check;
    if (res == chk) return res;
    status = check_zero_rows32(pm, MM_AUX_OFS_T / 32, 2 * 759);
    if (status < 0) return status;
    res |= status & check;
    if (res == chk) return res;
    status = check_zero_rows24(pm, MM_AUX_OFS_X / 32, 3 * 2048);
    if (status < 0) return status;
    res |= status & check;
    return res;
}



/*********************************************************************
** Compute a coarse hash value over a vector
*********************************************************************/


/**
  @brief Coarse hash value of structure of type mmv_fast_matrix_type

  The function compute a coarse has value over the matrix referred
  by pointer ``pa``. If  bit ``i`` in the argument ``check`` is zero
  then row ``i`` of the vector is ignored for the computation of the
  hash value.

  The intended use case is to hash over images of a fixed matrix
  under the action different elements of the Monster, where at least
  one of the considered row vectors is close to a random vector.
  For hashing over general matrices, this function is too coarse.

  Caution!

  This function is not portable between different implementations!
*/
// %%EXPORT p
uint64_t mm_op_fast_mode1_hash_coarse(mmv_fast_matrix_type *pm, uint32_t check)
{
  /// @cond DO_NOT_DOCUMENT 
     uint64_t mask = (check & 1) + ((check & 2) << 1)
                   + ((check & 4) << 3) + ((check & 8) << 3);
     uint64_t h = 0x1ULL;
     mmv_fast_type  *pf = ptr_data_mode1(pm);
     uint32_t i;
     if (pf == NULL) return 0;
     mask *= 0x0303030303030303ULL;
     #define CH 0x9e3779b97f4a7c15ULL // close to 2**63 * (sqrt(5)-1)
     #define hash(h, i) do { \
         uint64_t r = pf->u64[i] & mask; \
         uint64_t t = (r ^ (r >> 1))  & 0x5555555555555555ULL; \
         r &= t ^ (t << 1); \
         h = h * CH + r; \
     } while (0)

     zero_diagBC(pm);
     for (i = 0; i < MM_FAST_BYTELENGTH/8 - 1; i += 317) {
         i += ((i + 1) & 4) >> 2;
         hash(h, i);
     }
     for (i = MM_AUX_OFS_T/8 + 3; i < MM_AUX_OFS_X/8; i += 0x394) {
         hash(h, i);
     }
     #undef hash
     #undef CH
     return h;
  /// @endcond 
}











