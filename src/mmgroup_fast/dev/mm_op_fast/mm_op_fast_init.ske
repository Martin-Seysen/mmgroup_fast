/** @file mm_op_fast_init.c

 File ``mm_op_fast_init.c`` provides the basic functions for
 constructing structures of type ``mmv_fast_matrix_type``
 representing matrices of row vectors acting on the Griess algebra.
*/

/// @cond DO_NOT_DOCUMENT 
#define MM_OP_FAST_ALLOC
/// @endcond 

#include "mm_op_fast.h"
#include "mm_op_sub.h"   


//  %%GEN h
/// @cond DO_NOT_DOCUMENT 
//  %%GEN c




/**
   @brief Yet to be documented!
*/
// %%EXPORT p
int32_t mm_op_fast_init(mmv_fast_matrix_type *pm, uint32_t p, uint32_t nrows, uint32_t mode)
{
     // int32_t status;
     
     memset(pm, 0, sizeof(mmv_fast_matrix_type));
     switch (mode) {
         case 0:
             return 0;
         case 1:
             {
                 mmv_fast_type **p_buf = pm->p_v.p_vb, *ptr;
                 if (p != 3 ||  nrows > 4) return -1;
                 p_buf[0] = ptr = (mmv_fast_type*)mm_op_fast_buffer_alloc(
                     sizeof(mmv_fast_type));
                 ASSUME_ALIGNED(ptr, 64);
                 memset(ptr, 0, sizeof(mmv_fast_type));
                 p_buf[1] = NULL;
                 pm->mode = 1;
                 pm->p = p;
                 pm->nrows = nrows;
                 pm->current = 0;
                 pm->work_refcount = 0;
                 return 0;
             }
         default:
             return -1;
     }
}

/**
   @brief Yet to be documented!
*/
// %%EXPORT p
void mm_op_fast_dealloc(mmv_fast_matrix_type *pm)
{
     switch (pm->mode) {
         case 1:
             {
                 mmv_fast_type **p_buf = pm->p_v.p_vb;
                 if (p_buf[1] != NULL) {
                     mm_op_fast_buffer_free(p_buf[1], sizeof(mmv_fast_type));
                 }
                 if (p_buf[0] != NULL) {
                     mm_op_fast_buffer_free(p_buf[0], sizeof(mmv_fast_type));
                 }
             }
             break;
         default:
             break;
     }
     memset(pm, 0, sizeof(mmv_fast_matrix_type));
}







/**
   @brief Yet to be documented!
*/
// %%EXPORT p
int32_t mm_op_fast_alloc_work(mmv_fast_matrix_type *pm)
{
     switch (pm->mode) {
         case 1:
             {
                 if ((++pm->work_refcount) > 1) return 0;
                 mmv_fast_type **p_buf = pm->p_v.p_vb;
                 if (p_buf[1] == NULL) {
                     p_buf[1] = (mmv_fast_type*)mm_op_fast_buffer_alloc(
                         sizeof(mmv_fast_type));
                     if (p_buf[1] == NULL) return -1;
                     memset(p_buf[1], 0, sizeof(mmv_fast_type));
                 }
                 return 0;
             }
         default:
             return 0;
     }
}



/**
   @brief Yet to be documented!
*/
// %%EXPORT p
int32_t mm_op_fast_dealloc_work(mmv_fast_matrix_type *pm)
{
     switch (pm->mode) {
         case 1:
             {
                 if ((--pm->work_refcount) > 0) return 0;
                 mmv_fast_type **p_buf = pm->p_v.p_vb;
                 if (pm->current & 1) {
                      mmv_fast_type *tmp = p_buf[1];
                      p_buf[1] = p_buf[0]; p_buf[0] = tmp;
                 }
                 pm->current = 0;
                 if (p_buf[1] != NULL) {
                     mm_op_fast_buffer_free(p_buf[1], sizeof(mmv_fast_type));
                     p_buf[1] = NULL;
                 }
             }
         default:
             return 0;
     }
}


/**
   @brief copy data to an existing matrix of type mmv_fast_matrix_type

   The function copies data from matrix ``pm_src`` to the 
   matrix ``pm_dest``. Both matrices must be of the same type and shape.
*/
// %%EXPORT p
int32_t mm_op_fast_copy_data(mmv_fast_matrix_type *pm_src, mmv_fast_matrix_type *pm_dest)
{
     if (pm_src == NULL || pm_dest == NULL) return -1;
     if (pm_src->mode != pm_dest->mode || pm_src->p != pm_dest->p)
           return -1;
     
     switch (pm_src->mode) {
         case 1:
             {
                 pm_dest->nrows = pm_src->nrows;
                 mmv_fast_type **psrc_buf = pm_src->p_v.p_vb;
                 mmv_fast_type *psrc = psrc_buf[pm_src->current & 1];
                 ASSUME_ALIGNED(psrc, 64);
                 mmv_fast_type **pdest_buf = pm_dest->p_v.p_vb;
                 mmv_fast_type *pdest = pdest_buf[pm_dest->current & 1];
                 ASSUME_ALIGNED(pdest, 64);
                 memcpy(pdest, psrc, sizeof(mmv_fast_type));
             }
         default:
             return -1;
     }
}



/**
   @brief Yet to be documented!
*/
// %%EXPORT p
uint8_t* mm_op_fast_raw_vb_data(mmv_fast_matrix_type *pm, uint32_t *p_len)
{
     uint32_t len = 0;
     uint8_t *p_data = NULL;
     switch (pm->mode) {
         case 1:
             {
                 mmv_fast_type **p_buf = pm->p_v.p_vb;
                 p_data = (uint8_t*)(p_buf[pm->current & 1]);
                 len = sizeof(mmv_fast_type);
                 break;
             }
        default:
             break;
      }
      if (p_len != NULL) *p_len = (p_data = NULL) ? 0  : len;
      return p_data;
}







